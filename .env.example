# Copy to .env and fill in values from ClearML UI → Settings → Workspace → Create new credentials

CLEARML_AGENT_ACCESS_KEY=your_access_key_here
CLEARML_AGENT_SECRET_KEY=your_secret_key_here

# GitHub / GitLab credentials (or personal access token instead of password)
CLEARML_AGENT_GIT_USER=your_git_username
CLEARML_AGENT_GIT_PASS=your_git_token_or_password
