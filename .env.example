# ClearML API credentials
# Get from: UI → Settings → Workspace → Create new credentials
CLEARML_API_ACCESS_KEY=
CLEARML_API_SECRET_KEY=

# Git credentials for the agent (username + personal access token)
CLEARML_AGENT_GIT_USER=
CLEARML_AGENT_GIT_PASS=

# Serving service ID
# Get from: clearml-serving create --name "Sentiment Serving"
CLEARML_SERVING_TASK_ID=
